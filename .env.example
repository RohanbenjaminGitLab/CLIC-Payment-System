# Server
PORT=5000
CLIENT_URL=http://localhost:5173
# Comma-separated allowed frontend origins in production
# Example: https://clic-campus.vercel.app
COOKIE_SECURE=false

# JWT (use long random strings in production)
JWT_SECRET=change-me-to-a-long-random-secret-key-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_DAYS=7

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=clic_campus

# App
APP_NAME=CLIC Campus
INACTIVITY_MINUTES=30

# Frontend example for separate deployment (set inside client/.env.production)
# VITE_API_URL=https://clic-campus-api.onrender.com
