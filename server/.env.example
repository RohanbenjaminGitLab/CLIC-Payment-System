PORT=5000
CLIENT_URL=http://localhost:5173

# Cookie/session settings
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# JWT (use long random strings in production)
JWT_SECRET=change-me-to-a-long-random-secret-key-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_DAYS=7

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=clic_campus
DB_CONNECTION_LIMIT=5

# App
APP_NAME=CLIC Campus
INACTIVITY_MINUTES=30

# Optional manual webhook dispatch integration
WHATSAPP_REMINDER_WEBHOOK_URL=
